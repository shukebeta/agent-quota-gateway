# agent-quota-gateway environment file.
#
# Installed to /etc/agent-quota-gateway/aqg.env (0600 root:root). The deploy
# script copies this template only if no env file exists yet — it never
# overwrites your secrets on upgrade. Edit, then:
#
#   sudo systemctl restart agent-quota-gateway
#
# This file is read by the systemd manager and injected into the process;
# the DynamicUser service account never reads it directly.
#
# IMPORTANT — this is a systemd EnvironmentFile, NOT a shell script:
#   * one KEY=value per line; do NOT prefix lines with `export`.
#     (systemd silently ignores `export FOO=bar` AND logs the value to the
#     journal as an "invalid assignment" — a plaintext-secret leak.)
#   * no shell expansion, no $VAR, no command substitution, no quotes-as-shell.
#   * put ONLY this service's variables here. Do not point the unit at a
#     general-purpose secrets dump — the process would load credentials it
#     has no reason to hold.

# Shared mode: bind this host's Tailscale IP (find it with: tailscale ip -4).
# Must be a Tailscale address literal (100.64.0.0/10 or fd7a:115c:a1e0::/48).
# Omit this line entirely to run loopback-only (127.0.0.1:8080) instead.
SHARED_LISTEN_ADDR=100.64.0.0:9949

# Pools — at least one backend is required. See the README for the full
# AQG_POOL_<POOL>_BACKEND_<NICK> grammar, priority, and per-member URLs.
# AQG_POOL_AUTO_BACKEND_A=sk-ant-oat...
# AQG_POOL_AUTO_BACKEND_B=sk-ant-oat...
